<% layout("/layouts/boilerplate") %>

<style>
.tax-info{
    display:none;
}

/* ---------------- LISTINGS ---------------- */

.listing-card{
    border:none;
    margin-bottom:2rem;
    transition:.3s;
}

.listing-card:hover{
    transform:scale(1.02);
}

.listing-card img{
    width:100%;
    height:20rem;
    object-fit:cover;
    border-radius:1rem;
}

.listings{
    text-decoration:none;
    color:black;
}

.row{
    margin-top:1.5rem;
}



/* ---------------- FILTERS ---------------- */

#filters{
    display:flex;
    align-items:center;
    flex-wrap:wrap;
    gap:2rem;
    margin:1.5rem 0;
}

.filter{
    text-decoration:none;
    color:#717171;
    text-align:center;
    opacity:.8;
    border-bottom:2px solid transparent;
    padding-bottom:.5rem;
    transition:.25s;
}

.filter:hover{
    color:#222;
    opacity:1;
}

.filter i{
    font-size:1.3rem;
}

.filter p{
    margin-top:.4rem;
    margin-bottom:0;
    font-size:.82rem;
}

/* Active Filter */

.filter.active{
    color:#fe424d;
    opacity:1;
    border-bottom:2px solid #fe424d;
}

.filter.active i{
    color:#fe424d;
}

.filter.active p{
    color:#fe424d;
    font-weight:600;
}

/* ---------------- TAX TOGGLE ---------------- */

.tax-toggle{
    margin-left:auto;
    border:1px solid #dcdcdc;
    border-radius:1rem;
    padding:.8rem 1rem;
}

/* ---------------- MOBILE ---------------- */

@media(max-width:768px){

#filters{
    gap:1rem;
}

.tax-toggle{
    margin-left:0;
    width:100%;
}
}

.listing-card{
    position: relative;
}

.wishlist-btn{
    position:absolute;
    top:15px;
    right:15px;
    z-index:100;
}

.wishlist-btn button{
    background:none;
    border:none;
    padding:0;
    cursor:pointer;
}

.wishlist-btn i{
    font-size:30px;
    color:#ff385c;
    transition:.2s;
}

.wishlist-btn i:hover{
    transform:scale(1.15);
}




</style>

<div id="filters">

<a
href="<%= category==='Trending' ? '/listings' : '/listings?category=Trending' %>"
class="filter <%= category==='Trending' ? 'active' : '' %>">

<i class="fa-solid fa-fire"></i>
<p>Trending</p>

</a>

<a
href="<%= category==='Rooms' ? '/listings' : '/listings?category=Rooms' %>"
class="filter <%= category==='Rooms' ? 'active' : '' %>">

<i class="fa-solid fa-bed"></i>
<p>Rooms</p>

</a>

<a
href="<%= category==='Hi-tech cities' ? '/listings' : '/listings?category=Hi-tech cities' %>"
class="filter <%= category==='Hi-tech cities' ? 'active' : '' %>">

<i class="fa-solid fa-city"></i>
<p>Hi-tech cities</p>

</a>

<a
href="<%= category==='Farms' ? '/listings' : '/listings?category=Farms' %>"
class="filter <%= category==='Farms' ? 'active' : '' %>">

<i class="fa-solid fa-cow"></i>
<p>Farms</p>

</a>

<a
href="<%= category==='Camping' ? '/listings' : '/listings?category=Camping' %>"
class="filter <%= category==='Camping' ? 'active' : '' %>">

<i class="fa-solid fa-tent"></i>
<p>Camping</p>

</a>

<a
href="<%= category==='Amazing Pools' ? '/listings' : '/listings?category=Amazing Pools' %>"
class="filter <%= category==='Amazing Pools' ? 'active' : '' %>">

<i class="fa-solid fa-person-swimming"></i>
<p>Amazing Pools</p>

</a>

<a
href="<%= category==='Castles' ? '/listings' : '/listings?category=Castles' %>"
class="filter <%= category==='Castles' ? 'active' : '' %>">

<i class="fa-brands fa-fort-awesome"></i>
<p>Castles</p>

</a>

<a
href="<%= category==='Mountain' ? '/listings' : '/listings?category=Mountain' %>"
class="filter <%= category==='Mountain' ? 'active' : '' %>">

<i class="fa-solid fa-mountain"></i>
<p>Mountain</p>

</a>

<div class="tax-toggle">

<div class="form-check form-switch">

<input
class="form-check-input"
type="checkbox"
id="flexSwitchCheckDefault">

<label
class="form-check-label"
for="flexSwitchCheckDefault">

Display Total after Taxes!

</label>

</div>

</div>

</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

<% for(let list of l){ %>

<div class="col">

<a href="/listings/<%= list._id %>" class="listings">

<div class="card listing-card">

<% if(currUser){ %>

<div class="wishlist-btn">

<form action="/wishlist/<%= list._id %>" method="POST">

<button type="submit">

<% if(wishlist.includes(list._id.toString())){ %>

<i class="fa-solid fa-heart"></i>

<% } else { %>

<i class="fa-regular fa-heart"></i>

<% } %>

</button>

</form>

</div>

<% } %>

<img
src="<%= list.image.url %>"
class="card-img-top"
alt="listing_image">

<div class="card-body">

<p class="card-text">

<b><%= list.title %></b>

<br>

&#8377;<%= list.price.toLocaleString("en-IN") %>/night

<i class="tax-info">
&nbsp;+18% GST
</i>

</p>

</div>

</div>

</a>

</div>

<% } %>

</div>

<script>

const taxSwitch=document.getElementById("flexSwitchCheckDefault");

taxSwitch.addEventListener("change",()=>{

const taxInfo=document.getElementsByClassName("tax-info");

for(let info of taxInfo){

if(info.style.display==="inline"){
info.style.display="none";
}
else{
info.style.display="inline";
}

}

});

</script>