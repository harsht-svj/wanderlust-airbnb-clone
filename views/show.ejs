                <br>
                      <!-- <% if(currUser && review.author._id.equals(currUser._id)){ %> -->
                        <form method="POST"
                              action="/listings/<%= list._id %>/reviews/<%= review._id %>?_method=DELETE">
                            <button class="btn btn-sm btn-dark px-3 py-1">
                                Delete
