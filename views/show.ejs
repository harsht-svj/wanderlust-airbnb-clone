    background:none;
    border:none;
    padding:0;
    cursor:pointer;
}

.wishlist-btn i{
    font-size:32px;
    color:#ff385c;
}
</style>
<script>
//PULBIC FOLDERS ME DIRECT ENV FILES KO USE NI KR SKTE TO YHA PE STORE KRKE PUBLIC ME USE KREGE 
let mapToken = "<%= process.env.MAP_TOKEN %>";
const listing = <%- JSON.stringify(list) %>;
const bookedDates = <%- JSON.stringify(bookedDates) %>;
const coordinates =
    (listing.geometry &&
     Array.isArray(listing.geometry.coordinates) &&
     listing.geometry.coordinates.length === 2)
        ? listing.geometry.coordinates
        : [77.2090, 28.6139]; // New Delhi

</script>


<div class="container mt-5 mb-5" style="max-width: 700px;">

    <!-- TITLE -->
    <h4 class="mb-3 fw-semibold"><%= list.title %></h4>

    <!-- IMAGE -->
<div class="listing-img">

    <% if(currUser){ %>
    <div class="wishlist-btn">
        <form action="/wishlist/<%= list._id %>" method="POST">
            <button type="submit">

                <% if(wishlist.includes(list._id.toString())){ %>
                    <i class="fa-solid fa-heart"></i>
                <% } else { %>
                    <i class="fa-regular fa-heart"></i>
                <% } %>

            </button>
        </form>
    </div>
    <% } %>

    <img src="<%= list.image.url %>"
         class="img-fluid rounded mb-4"
         style="width:100%;height:280px;object-fit:cover;"
         alt="listing image">

</div>

    <!-- OWNER -->
    <p class="mb-1 fw-semibold">
        <b>Owner:</b> <%= list.owner.username %>
    </p>

    <!-- DESCRIPTION -->
    <p class="text-muted mb-2">
        <b>Description:</b> <%= list.description %>
    </p>




<div class="card shadow-sm p-4 mt-4">

    <h4 class="mb-3">
        ₹ <%= list.price.toLocaleString("en-IN") %>
        <small class="text-muted"> / night</small>
    </h4>

    <% if(!currUser){ %>

        <a href="/login" class="btn btn-dark w-100">
            Login to Book
        </a>

    <% }else if(myBooking){ %>

        <div class="alert alert-success">

            <h5 class="mb-3">
                ✅ You have already booked this property.
            </h5>

            <p class="mb-2">
                <strong>Check In:</strong>
                <%= myBooking.checkIn.toDateString() %>
            </p>

            <p class="mb-2">
                <strong>Check Out:</strong>
                <%= myBooking.checkOut.toDateString() %>
            </p>

            <p class="mb-3">
                <strong>Total Paid:</strong>
                ₹ <%= myBooking.totalPrice.toLocaleString("en-IN") %>
            </p>

        <div class="d-flex justify-content-between align-items-end mt-4">

    <a
        href="/bookings/mybookings"
        class="btn btn-dark"
    >
        <i class="fa-solid fa-calendar-check"></i>
        My Bookings
    </a>

    <form
        action="/bookings/<%= myBooking._id %>?_method=DELETE"
        method="POST"
    >
        <button
            class="btn btn-outline-danger"
            onclick="return confirm('Are you sure you want to cancel this booking?')"
        >
            <i class="fa-solid fa-xmark"></i>
            Cancel Booking
        </button>
    </form>

</div>

        </div>

    <% }else{ %>

        <form action="/bookings/<%= list._id %>" method="POST">

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        Check In
                    </label>

                    <input
                       type="text"
    id="checkIn"
    autocomplete="off"
                        name="checkIn"
                        class="form-control"
                        required
                    >

                </div>

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        Check Out
                    </label>

                    <input
                        type="text"
                        id="checkOut"
                        name="checkOut"
                        autocomplete="off"
                        class="form-control"
                        required
                    >

                </div>

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Guests
                </label>

                <input
                    type="number"
                    name="guests"
                    class="form-control"
                    value="1"
                    min="1"
                    max="10"
                    required
                >

            </div>

            <div class="alert alert-light border">

                <p class="mb-2">

                    Nights :
                    <strong id="nights">
                        0
                    </strong>

                </p>

                <p class="mb-0">

                    Total :

                    <strong id="totalPrice">
                        ₹0
                    </strong>

                </p>

            </div>

            <button class="btn btn-dark w-100">

                Reserve

            </button>

        </form>

    <% } %>

</div>
<script>

if(document.getElementById("checkIn")){

const price=<%= list.price %>;

const checkIn=document.getElementById("checkIn");
const checkOut=document.getElementById("checkOut");

const total=document.getElementById("totalPrice");
const nights=document.getElementById("nights");

function calculate(){

    if(!checkIn.value || !checkOut.value){

        total.innerText="₹0";
        nights.innerText="0";
        return;

    }

    const inDate=new Date(checkIn.value);
    const outDate=new Date(checkOut.value);

    if(outDate<=inDate){

        total.innerText="₹0";
        nights.innerText="0";
        return;

    }

    const diff=(outDate-inDate)/(1000*60*60*24);

    nights.innerText=diff;

    total.innerText="₹"+(diff*price).toLocaleString("en-IN");

}

flatpickr("#checkIn",{

    dateFormat:"Y-m-d",

    minDate:"today",

    disable:bookedDates,

    onChange:function(selectedDates){

        if(selectedDates.length){

            checkOut._flatpickr.set(
                "minDate",
                selectedDates[0]
            );

        }

        calculate();

    }

});

flatpickr("#checkOut",{

    dateFormat:"Y-m-d",

    minDate:"today",

    disable:bookedDates,

    onChange:function(){

        calculate();

    }

});

}

</script>


<br>
    <!-- LOCATION -->
    <p class="text-muted">
        <b>Location:</b> <%= list.location %><br>
        <b>Country:</b> <%= list.country %>
    </p>

    <!-- EDIT & DELETE BUTTONS -->
    <% if(currUser && currUser._id.equals(list.owner._id)){ %>
        <div class="d-flex gap-3 mt-3">
            <a href="/listings/<%= list._id %>/edit"
               class="btn btn-danger px-4">
                Edit
            </a>

