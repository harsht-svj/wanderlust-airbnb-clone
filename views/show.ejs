                        </form>
                    <!-- <% } %> -->

            </div>

        </div>

    <% } %>


</div>
<% }  %>
<br><br>


<div class="col-6 mb-4">
    <h3 class="map-title">Your Location: </h3>
        <div id="map"></div>
</div>


