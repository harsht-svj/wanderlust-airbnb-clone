<% layout("/layouts/boilerplate") %>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap mb-4">
        <h2 class="mb-0">❤️ My Wishlist</h2>

        <div class="tax-toggle">
            <div class="form-check form-switch mb-0">
                <input
                    class="form-check-input"
                    type="checkbox"
                    id="flexSwitchCheckDefault">
                <label
                    class="form-check-label"
                    for="flexSwitchCheckDefault">
                    Display Total after Taxes!
                </label>
            </div>
        </div>
    </div>

    <% if(l.length === 0){ %>

        <div class="text-center mt-5 mb-5">
            <h3>Your wishlist is empty</h3>
            <p class="text-muted">Tap the heart on any listing to save it here.</p>
            <a href="/listings" class="btn btn-danger mt-3">
                Explore Listings
            </a>
        </div>

    <% } else { %>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

            <% for(let list of l){ %>

                <div class="col">
                    <div class="card listing-card">

                        <% if(currUser){ %>
                            <div class="wishlist-btn">
                                <form action="/wishlist/<%= list._id %>" method="POST">
                                    <button type="submit">
                                        <% if(wishlist.includes(list._id.toString())){ %>
                                            <i class="fa-solid fa-heart"></i>
                                        <% } else { %>
                                            <i class="fa-regular fa-heart"></i>
                                        <% } %>
                                    </button>
                                </form>
                            </div>
                        <% } %>

                        <a href="/listings/<%= list._id %>" class="listings">
                            <img
                                src="<%= list.image.url %>"
                                class="card-img-top"
                                alt="listing_image">

                            <div class="card-body">
                                <p class="card-text">
                                    <b><%= list.title %></b>
                                    <br>
                                    &#8377;<%= list.price.toLocaleString("en-IN") %>/night
                                    <i class="tax-info">&nbsp;+18% GST</i>
                                </p>
                            </div>
                        </a>

                    </div>
                </div>

            <% } %>

        </div>

    <% } %>
</div>

<style>
.tax-info{
    display:none;
}

/* ---------------- LISTINGS ---------------- */

.listing-card{
    border:none;
    margin-bottom:1rem;
    position:relative;
    transition:.3s;
}

.listing-card:hover{
    transform:scale(1.02);
}

.listing-card img{
    width:100%;
    height:20rem;
    object-fit:cover;
    border-radius:1rem;
}

.listings{
    text-decoration:none;
    color:black;
}

/* ---------------- WISHLIST HEART BUTTON ---------------- */

.wishlist-btn{
    position:absolute;
    top:15px;
    right:15px;
    z-index:10;
}

.wishlist-btn button{
    background:none;
    border:none;
    padding:0;
    cursor:pointer;
}

.wishlist-btn i{
    font-size:1.6rem;
    color:#ff385c;
    transition:.2s;
}

.wishlist-btn i:hover{
    transform:scale(1.15);
}

/* ---------------- TAX TOGGLE ---------------- */

.tax-toggle{
    border:1px solid #dcdcdc;
    border-radius:1rem;
    padding:.6rem 1rem;
}

/* ---------------- MOBILE ---------------- */

@media(max-width:768px){
    .tax-toggle{
        width:100%;
        margin-top:1rem;
    }
}
</style>

<script>
const taxSwitch = document.getElementById("flexSwitchCheckDefault");

taxSwitch.addEventListener("change", () => {
    const taxInfo = document.getElementsByClassName("tax-info");

    for (let info of taxInfo) {
        info.style.display = taxSwitch.checked ? "inline" : "none";
    }
});
</script>